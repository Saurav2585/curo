{
  "$meta": {
    "product": "Curo",
    "version": "1.0.0",
    "description": "Primitives -> semantic -> component. Raw values carry no meaning; semantic tokens assign it; component tokens apply it. Nothing in the codebase may reference a primitive directly.",
    "contrastTarget": "WCAG 2.2 AA - 4.5:1 body text, 3:1 large text and non-text UI"
  },

  "primitives": {
    "color": {
      "teal": {
        "50":  "#E6F4F6",
        "100": "#C2E5EA",
        "200": "#99D4DC",
        "300": "#66BECA",
        "400": "#2E9FAF",
        "500": "#028090",
        "600": "#02707E",
        "700": "#015C68",
        "800": "#014753",
        "900": "#01343D",
        "950": "#001F25"
      },
      "neutral": {
        "0":   "#FFFFFF",
        "50":  "#F8FAFA",
        "100": "#F1F4F5",
        "200": "#E3E8EA",
        "300": "#CBD3D6",
        "400": "#94A2A7",
        "500": "#6B787D",
        "600": "#556166",
        "700": "#414B50",
        "800": "#2C3437",
        "900": "#1A2023",
        "950": "#0E1214"
      },
      "amber": {
        "50":  "#FFFBEB",
        "100": "#FEF3C7",
        "300": "#FCD34D",
        "500": "#D97706",
        "600": "#B45309",
        "700": "#92400E"
      },
      "green": {
        "50":  "#ECFDF5",
        "100": "#D1FAE5",
        "500": "#059669",
        "600": "#047857",
        "700": "#065F46"
      },
      "red": {
        "50":  "#FEF2F2",
        "100": "#FEE2E2",
        "500": "#DC2626",
        "600": "#B91C1C",
        "700": "#991B1B"
      }
    },

    "font": {
      "family": {
        "sans": "Inter, system-ui, -apple-system, 'Segoe UI', sans-serif",
        "mono": "'JetBrains Mono', ui-monospace, monospace"
      },
      "size": {
        "xs":   "0.75rem",
        "sm":   "0.8125rem",
        "base": "0.9375rem",
        "md":   "1rem",
        "lg":   "1.25rem",
        "xl":   "1.5rem",
        "2xl":  "2rem",
        "3xl":  "3rem"
      },
      "weight": { "regular": "400", "medium": "500", "semibold": "600", "bold": "700" },
      "lineHeight": { "tight": "1.2", "snug": "1.35", "normal": "1.5", "relaxed": "1.65" },
      "feature": { "tabular": "'tnum' 1, 'cv05' 1" }
    },

    "space": {
      "0": "0", "1": "0.25rem", "2": "0.5rem", "3": "0.75rem", "4": "1rem",
      "5": "1.25rem", "6": "1.5rem", "8": "2rem", "10": "2.5rem",
      "12": "3rem", "16": "4rem", "20": "5rem"
    },

    "radius": { "none": "0", "sm": "0.375rem", "md": "0.5rem", "lg": "0.75rem", "xl": "1rem", "full": "9999px" },

    "shadow": {
      "sm": "0 1px 2px 0 rgb(14 18 20 / 0.05)",
      "md": "0 4px 12px -2px rgb(14 18 20 / 0.08), 0 2px 4px -2px rgb(14 18 20 / 0.04)",
      "lg": "0 12px 32px -8px rgb(14 18 20 / 0.12)"
    },

    "motion": {
      "duration": { "fast": "120ms", "base": "180ms", "slow": "240ms" },
      "easing": { "out": "cubic-bezier(0.16, 1, 0.3, 1)", "inOut": "cubic-bezier(0.65, 0, 0.35, 1)" }
    },

    "border": { "hairline": "1px", "thick": "2px" }
  },

  "semantic": {
    "light": {
      "bg": {
        "canvas":     "{color.neutral.50}",
        "surface":    "{color.neutral.0}",
        "raised":     "{color.neutral.0}",
        "sunken":     "{color.neutral.100}",
        "inverse":    "{color.neutral.900}",
        "brandSubtle":"{color.teal.50}",
        "brand":      "{color.teal.500}",
        "brandHover": "{color.teal.600}",
        "successSubtle": "{color.green.50}",
        "warnSubtle":    "{color.amber.50}",
        "dangerSubtle":  "{color.red.50}"
      },
      "text": {
        "primary":   "{color.neutral.900}",
        "secondary": "{color.neutral.700}",
        "muted":     "{color.neutral.600}",
        "disabled":  "{color.neutral.400}",
        "onBrand":   "{color.neutral.0}",
        "onInverse": "{color.neutral.50}",
        "brand":     "{color.teal.600}",
        "success":   "{color.green.700}",
        "warn":      "{color.amber.700}",
        "danger":    "{color.red.700}"
      },
      "border": {
        "$comment": "subtle/default are DECORATIVE (dividers, card edges) and exempt from 1.4.11. control/strong bound interactive elements and must clear 3:1.",
        "subtle":  "{color.neutral.200}",
        "default": "{color.neutral.300}",
        "control": "{color.neutral.500}",
        "strong":  "{color.neutral.600}",
        "brand":   "{color.teal.500}",
        "focus":   "{color.teal.600}",
        "danger":  "{color.red.500}"
      }
    },

    "dark": {
      "bg": {
        "canvas":     "{color.neutral.950}",
        "surface":    "{color.neutral.900}",
        "raised":     "{color.neutral.800}",
        "sunken":     "{color.neutral.950}",
        "inverse":    "{color.neutral.50}",
        "brandSubtle":"{color.teal.900}",
        "brand":      "{color.teal.400}",
        "brandHover": "{color.teal.300}",
        "successSubtle": "{color.green.700}",
        "warnSubtle":    "{color.amber.700}",
        "dangerSubtle":  "{color.red.700}"
      },
      "text": {
        "primary":   "{color.neutral.50}",
        "secondary": "{color.neutral.200}",
        "muted":     "{color.neutral.300}",
        "disabled":  "{color.neutral.500}",
        "onBrand":   "{color.neutral.950}",
        "onInverse": "{color.neutral.900}",
        "brand":     "{color.teal.300}",
        "success":   "{color.green.100}",
        "warn":      "{color.amber.100}",
        "danger":    "{color.red.100}"
      },
      "border": {
        "subtle":  "{color.neutral.800}",
        "default": "{color.neutral.700}",
        "control": "{color.neutral.400}",
        "strong":  "{color.neutral.300}",
        "brand":   "{color.teal.400}",
        "focus":   "{color.teal.300}",
        "danger":  "{color.red.500}"
      }
    }
  },

  "component": {
    "slot": {
      "$comment": "The signature component. State is carried by colour AND border weight AND label, never colour alone.",
      "available": {
        "bg": "{bg.surface}",
        "text": "{text.brand}",
        "border": "{border.brand}",
        "borderWidth": "{border.hairline}",
        "label": "Available"
      },
      "fillingFast": {
        "bg": "{bg.warnSubtle}",
        "text": "{text.warn}",
        "border": "{color.amber.500}",
        "borderWidth": "{border.thick}",
        "label": "Filling fast"
      },
      "booked": {
        "bg": "{bg.sunken}",
        "text": "{text.muted}",
        "border": "{border.subtle}",
        "borderWidth": "{border.hairline}",
        "label": "Booked"
      },
      "selected": {
        "bg": "{bg.brand}",
        "text": "{text.onBrand}",
        "border": "{border.brand}",
        "borderWidth": "{border.thick}",
        "label": "Selected"
      },
      "size": { "minWidth": "5.5rem", "height": "2.75rem", "radius": "{radius.md}", "gap": "{space.2}" }
    },

    "button": {
      "primary":   { "bg": "{bg.brand}", "bgHover": "{bg.brandHover}", "text": "{text.onBrand}", "border": "transparent" },
      "secondary": { "bg": "{bg.surface}", "bgHover": "{bg.sunken}", "text": "{text.primary}", "border": "{border.control}" },
      "ghost":     { "bg": "transparent", "bgHover": "{bg.sunken}", "text": "{text.secondary}", "border": "transparent" },
      "danger":    { "bg": "{color.red.600}", "bgHover": "{color.red.700}", "text": "{color.neutral.0}", "border": "transparent" },
      "size": {
        "sm": { "height": "2rem",    "paddingX": "{space.3}", "fontSize": "{font.size.sm}" },
        "md": { "height": "2.5rem",  "paddingX": "{space.4}", "fontSize": "{font.size.base}" },
        "lg": { "height": "3rem",    "paddingX": "{space.6}", "fontSize": "{font.size.md}" }
      },
      "radius": "{radius.md}",
      "focusRing": "0 0 0 2px {bg.surface}, 0 0 0 4px {border.focus}"
    },

    "input": {
      "bg": "{bg.surface}",
      "text": "{text.primary}",
      "placeholder": "{text.disabled}",
      "border": "{border.control}",
      "borderHover": "{border.strong}",
      "borderFocus": "{border.focus}",
      "borderError": "{border.danger}",
      "height": "2.5rem",
      "paddingX": "{space.3}",
      "radius": "{radius.md}"
    },

    "card": {
      "bg": "{bg.surface}",
      "border": "{border.subtle}",
      "radius": "{radius.lg}",
      "padding": "{space.5}",
      "shadow": "{shadow.sm}",
      "shadowHover": "{shadow.md}"
    },

    "badge": {
      "neutral": { "bg": "{bg.sunken}",        "text": "{text.muted}" },
      "brand":   { "bg": "{bg.brandSubtle}",   "text": "{text.brand}" },
      "success": { "bg": "{bg.successSubtle}", "text": "{text.success}" },
      "warn":    { "bg": "{bg.warnSubtle}",    "text": "{text.warn}" },
      "danger":  { "bg": "{bg.dangerSubtle}",  "text": "{text.danger}" },
      "radius": "{radius.full}",
      "fontSize": "{font.size.xs}",
      "paddingX": "{space.2}"
    },

    "table": {
      "headerBg": "{bg.sunken}",
      "headerText": "{text.muted}",
      "rowBorder": "{border.subtle}",
      "rowHoverBg": "{bg.canvas}",
      "cellPaddingY": "{space.3}",
      "cellPaddingX": "{space.4}",
      "numericAlign": "right",
      "numericFeature": "{font.feature.tabular}"
    }
  }
}
